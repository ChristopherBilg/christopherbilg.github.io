{
  "version": "1.0.0-dev",
  "environment": "dev",
  "features": {
    "allowCancellation": true,
    "allowPilotReassignment": true,
    "allowDelay": true,
    "strictStateTransitions": true
  },
  "adapters": {
    "Airport": "json",
    "Pilot": "json",
    "Flight": "json"
  },
  "dataSources": {
    "Airport": "./data/airports.json",
    "Pilot":   "./data/pilots.json",
    "Flight":  "./data/flights.json"
  }
}
